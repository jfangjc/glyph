<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="glyph.exe"
        Arguments=""
        InstallLocation="C:\Program Files\Glyph\Glyph">
    </Installer>
    <PackageInformation
        PackageName="app.glyph.editor"
        PackageDisplayName="Glyph"
        PublisherName="CN=Glyph"
        PublisherDisplayName="Glyph"
        Version="0.0.1.0"
        PackageDescription="A focused editor for Markdown, LaTeX, Org Mode, Typst, and plain text.">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="app.glyph.editor"
                Description="A focused editor for Markdown, LaTeX, Org Mode, Typst, and plain text."
                DisplayName="Glyph"
                ExecutableName="glyph.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Glyph</DisplayName>
            <PublisherDisplayName>Glyph</PublisherDisplayName>
            <Description>A focused editor for Markdown, LaTeX, Org Mode, Typst, and plain text.</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="glyph.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
