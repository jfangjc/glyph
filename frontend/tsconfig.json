{
    "compilerOptions": {
        "noEmit": true,
        "skipLibCheck": true,

        "module": "ESNext",
        "moduleResolution": "node",
        "resolveJsonModule": true,
        "isolatedModules": true,

        "lib": ["DOM", "DOM.Iterable", "ESNext"],

        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": false,
        "noImplicitAny": false,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
    },
    "include": ["src"],
}
